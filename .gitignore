# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python
venv/
env/
.venv/

# Test coverage
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# Environment
.env
*.env
!.env.example

# Output
output/*.json
output/*.xlsx
output/*.txt
output/*.jsonl
output/*.pdf
output/*.csv
output/*.html
output/.cache/
output/_runtime_settings.json
!output/.gitkeep

# Test drawings (user-specific, often confidential)
draws/

# User reports folder (local experiments — often confidential drawings)
REPORTS/

# Demo pack contents (only README + HTML demo tracked; binary outputs are local)
demo_pack/*
!demo_pack/.gitkeep
!demo_pack/README.md
!demo_pack/interactive_demo.html

# Sample drawings — README + the 3 generated demo PDFs are tracked.
# Real customer drawings (if accidentally placed here) are still ignored.
sample_drawings/*
!sample_drawings/.gitkeep
!sample_drawings/README.md
!sample_drawings/01_*.pdf
!sample_drawings/02_*.pdf
!sample_drawings/03_*.pdf

# Backup files
*.bak
*.orig

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Streamlit
.streamlit/secrets.toml

# Claude Code local files
.claude/

# Temp files
*.tmp
_asm_temp_*
